# ═══════════════════════════════════════════════════════════════════════
#  REQUIRED — the app needs these two to run (local + Vercel/hosted)
# ═══════════════════════════════════════════════════════════════════════

# Signs login session cookies. Use a long random string.
#   generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# Firebase Admin service account (server-side DB + auth store).
# LOCAL dev: you can instead drop the key file as service-account.json in the
# project root and leave this blank.
# HOSTED (Vercel): paste the WHOLE service-account JSON as the value here
# (one line is fine), or a base64-encoded version of it.
#   Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# ═══════════════════════════════════════════════════════════════════════
#  OPTIONAL
# ═══════════════════════════════════════════════════════════════════════

# Firebase Web SDK config — NOT currently used by the app (the client talks to
# secure server APIs, not Firestore directly). Safe to leave blank.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Email sending — used by the Firebase Cloud Functions only (deployed to
# Firebase, NOT Vercel). Not needed by the Vercel app.
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SEND_FROM="OneGrasp Conferences <conferences@onegrasp.com>"
